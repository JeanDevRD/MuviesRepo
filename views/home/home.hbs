<div class="row mb-3">
  <h1><i class="bi bi-camera-reels"></i> Series disponibles</h1>
  <hr />
</div>

<div class="row mb-4">
  <div class="col-12 col-sm-5 mb-2">
    <form method="get" action="/" class="d-flex gap-2">
      <input type="text" name="search" class="form-control"
        placeholder="Buscar por nombre..." value="{{searchValue}}" />
      <button type="submit" class="btn btn-dark text-nowrap">
        <i class="bi bi-search"></i> Buscar
      </button>
    </form>
  </div>
  <div class="col-12 col-sm-5 mb-2">
    <form method="get" action="/" class="d-flex gap-2">
      <select name="genreId" class="form-select">
        <option value="">-- Todos los géneros --</option>
        {{#each genresList}}
          <option value="{{this.id}}" {{#if (eq this.id ../selectedGenre)}}selected{{/if}}>
            {{this.name}}
          </option>
        {{/each}}
      </select>
      <button type="submit" class="btn btn-dark text-nowrap">
        <i class="bi bi-funnel"></i> Filtrar
      </button>
    </form>
  </div>
</div>

{{#if hasSeries}}
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    {{#each seriesList}}
      <div class="col">
        <div class="card h-100 shadow-sm">
          <img src="{{this.coverImage}}" class="card-img-top" alt="{{this.name}}"
            style="height: 220px; object-fit: cover;"
            onerror="this.src='https://placehold.co/300x220?text=Sin+imagen'" />
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">{{this.name}}</h5>
            <p class="card-text text-muted small">
              <i class="bi bi-tag"></i> {{getGenreName ../genresList this.genreId}}
            </p>
            <div class="mt-auto">
              <a href="/series/detail/{{this.id}}" class="btn btn-dark w-100">
                <i class="bi bi-play-fill"></i> Ver detalle
              </a>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="row d-flex justify-content-center">
    <div class="col-12 col-sm-5">
      <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No se encontraron series.
      </div>
    </div>
  </div>
{{/if}}