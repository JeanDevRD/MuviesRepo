<div class="row mb-3">
  <h1><i class="bi bi-play-circle"></i> Series</h1>
  <hr />
</div>

<div class="row mb-3">
  <div class="col-12">
    <a href="/series/create" class="btn btn-success">
      <i class="bi bi-plus-circle"></i> Nueva serie
    </a>
  </div>
</div>

{{#if hasSeries}}
  <div class="row">
    {{#each seriesList}}
      <div class="col-12 col-sm-4 col-md-3 mb-4">
        <div class="card h-100 shadow-sm">
          <img src="{{this.coverImage}}" class="card-img-top" alt="{{this.name}}"
            style="height: 200px; object-fit: cover;"
            onerror="this.src='https://placehold.co/300x200?text=Sin+imagen'" />
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">{{this.name}}</h5>
            <p class="card-text text-muted small">
              <i class="bi bi-tag"></i> {{getGenreName ../genresList this.genreId}}
            </p>
            <div class="mt-auto d-flex gap-2">
              <a href="/series/edit/{{this.id}}" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil"></i> Editar
              </a>
              <form method="post" action="/series/delete">
                <input type="hidden" name="id" value="{{this.id}}" />
                <button type="submit" class="btn btn-danger btn-sm confirm-delete"
                  data-name="{{this.name}}">
                  <i class="bi bi-trash3"></i> Eliminar
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="row d-flex justify-content-center">
    <div class="col-12 col-sm-5">
      <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No hay series registradas.
      </div>
    </div>
  </div>
{{/if}}

{{#section "scripts"}}
<script>
  document.querySelectorAll(".confirm-delete").forEach((btn) => {
    btn.addEventListener("click", function (e) {
      if (!confirm(`¿Está seguro que desea eliminar esta serie?`)) {
        e.preventDefault();
      }
    });
  });
</script>
{{/section}}